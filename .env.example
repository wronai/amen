# ITERUN Configuration
# Copy this file to .env and adjust values

# =============================================================================
# SERVER SETTINGS
# =============================================================================
HOST=0.0.0.0
PORT=8080
DEBUG=false
LOG_LEVEL=INFO

# =============================================================================
# AI GATEWAY — LiteLLM (OpenRouter lub Ollama)
# =============================================================================
AI_ENABLED=true

# OpenRouter (zalecane gdy masz klucz) — LLM_MODEL ma pierwszeństwo nad DEFAULT_MODEL
OPENROUTER_API_KEY=sk-or-...
LLM_MODEL=openrouter/deepseek/deepseek-v4-pro

# Ollama (lokalny fallback / suggest w shell)
OLLAMA_BASE_URL=http://localhost:11434
DEFAULT_MODEL=llama3.2
MAX_MODEL_PARAMS=12.0
OLLAMA_TIMEOUT=120

# Opcjonalnie inne providery
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# =============================================================================
# EXECUTION SETTINGS
# =============================================================================
DOCKER_ENABLED=true
WORKSPACE_DIR=/tmp/iterun
AUTO_EXECUTE=true
SKIP_ITERUN_CONFIRMATION=true

# =============================================================================
# DOCKER CONTAINER SETTINGS
# =============================================================================
CONTAINER_PORT=8000
CONTAINER_PREFIX=intent

# =============================================================================
# VALIDATION & AUTO-FIX SETTINGS
# =============================================================================
# Enable post-execution validation
VALIDATE_AFTER_EXECUTE=true
# Enable automatic fixing if validation fails
AUTO_FIX_ENABLED=true
# Maximum auto-fix iterations
MAX_FIX_ITERATIONS=3
# Seconds to wait for container startup before validation
STARTUP_WAIT=2
# Validation request timeout in seconds
VALIDATION_TIMEOUT=10
